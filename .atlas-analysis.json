  "keyFeatures": [
    "AES-256-GCM encryption with per-value unique salt and IV",
    "Split master key architecture across Convex and Cloudflare KV",
    "Telegram approval for runtime access",
    "Hot-reload secrets without process restart",
    "Trusted restart with 24-hour permit tokens",
    "CLI for secrets management and encryption",
    "Zero disk writes - secrets decrypted in RAM only"
  ],
  "publicApiSurface": [
